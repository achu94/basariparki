---
import config from "@/config/config.json";
---

<section id="about" class="section bg-white relative overflow-hidden">
	<!-- Background Decoration -->
	<div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-blue-500/5 blur-3xl"></div>
	<div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-pink-500/5 blur-3xl"></div>

	<div class="container relative z-10">
		<!-- Section Header -->
		<div class="text-center mb-16">
			<div class="inline-block mb-4 px-4 py-2 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 text-white text-sm font-semibold animate-fade-in-up">
				Über uns
			</div>
			<h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-gray-900 animate-fade-in-up">
				Unser Konzept
			</h2>
			<p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto animate-fade-in" style="animation-delay: 0.2s;">
				Bei {config.site.name} steht das Wohl und die Entwiklung Ihres
				Kindes an erster Stelle. Wir bieten eine liebevolle und
				anregende Umgebung für kleine Entdecker.
			</p>
		</div>

		<!-- About Content -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
			<!-- Left: Mission -->
			<div class="animate-fade-in-up" style="animation-delay: 0.3s;">
				<div class="p-8 rounded-2xl bg-gradient-to-br from-blue-50 to-purple-50 shadow-xl border border-gray-100">
					<div class="text-5xl mb-6">🎯</div>
					<h3 class="text-2xl font-bold mb-4 text-gray-900">
						Unsere Mission
					</h3>
					<p class="text-gray-600 leading-relaxed mb-6">
						Kinder spielerisch und sicher förhren, um ihr
						natürliches Entwiklungspotenzial optimal zu entfalten. Jeden Tag
						neue Erlebnisse und Lernmomente schaffen.
					</p>
					<div class="flex flex-wrap gap-3">
						{["Sicherheit", "Spaß", "Förderung", "Gemeinschaft"].map((item) => (
							<span class="px-3 py-1 rounded-full bg-white/80 text-sm font-semibold text-primary">
								{item}
							</span>
						))}
					</div>
				</div>
			</div>

			<!-- Right: Werte -->
			<div class="space-y-6 animate-fade-in-up" style="animation-delay: 0.4s;">
				{[
					{
						title: "Pädagogische Qualität",
						description:
							"Unser erfahrenes Team besteht aus qualifizierten Erziehern mit pädagogischem Hintergrund.",
						icon: "👩‍🏫",
					},
					{
						title: "Sicherheit an erster Stelle",
						description:
							"Alle Spielbereiche und Materialien sind nach strengen Sicherheitsstandards ausgewählt und geprüft.",
						icon: "🛡️",
					},
					{
						title: "Individuelle Förderung",
						description:
							"Wir berücksichtigen die Bedürfnisse und das Tempo jedes einzelnen Kindes.",
						icon: "🌟",
					},
					{
						title: "Transparente Kommunikation",
						description:
							"Regelmäßiger Austausch mit Eltern über den Tag und die Entwiklung des Kindes.",
						icon: "💬",
					},
				].map((item, index) => (
					<div
						class="group flex items-start gap-4 p-6 rounded-xl bg-white shadow-md hover:shadow-lg border border-gray-100 transition-all duration-300 hover:-translate-x-2"
						style={`animation-delay: ${0.5 + index * 0.1}s;`}
					>
						<div class="text-3xl group-hover:scale-110 transition-transform duration-300">
							{item.icon}
						</div>
						<div>
							<h4 class="font-semibold mb-2 text-gray-900">
								{item.title}
							</h4>
							<p class="text-sm text-gray-600">
								{item.description}
							</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
